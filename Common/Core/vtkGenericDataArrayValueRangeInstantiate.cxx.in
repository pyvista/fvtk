// We only compile the 64-bit integer range compulation for value types
// of long, unsigned long, long long, and unsigned long log.  All others
// reuse the double-precision vtkDataArray::GetRange version, since they
// won't lose precision.

#define VTK_GDA_VALUERANGE_INSTANTIATING
#include "vtkGenericDataArray.h"
// vtkDataArrayPrivate.txx's scalar-range code uses vtkSOADataArrayTemplate<T> and
// vtkScaledSOADataArrayTemplate<T> as COMPLETE types (it calls their members),
// regardless of the VTK_DISPATCH_*SOA* switches. In the stock single "bulk" TU an
// earlier #include of the SOA instantiation sources already pulled in those
// template DEFINITIONS, so the type was complete. When this instantiation is
// compiled as its own TU (cvista CVISTA_SPLIT_BULK_INSTANTIATE — split for build
// parallelism), that sharing is gone, so include the .txx definitions here. These
// are plain header includes (no VTK_*_INSTANTIATING define), so they only make the
// templates COMPLETE — they do NOT force any explicit instantiation, and the
// include guards make this a no-op in the bulk layout (object code unchanged).
#include "vtkSOADataArrayTemplate.txx"
#include "vtkScaledSOADataArrayTemplate.txx"
#include "vtkDataArrayPrivate.txx"

namespace vtkDataArrayPrivate
{
VTK_ABI_NAMESPACE_BEGIN
VTK_INSTANTIATE_VALUERANGE_VALUETYPE(@INSTANTIATION_VALUE_TYPE@)
VTK_ABI_NAMESPACE_END
}
