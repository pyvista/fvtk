# See vtk-config.cmake.in for why the data directory is globbed rather than
# addressed by the package version.
file(GLOB _cvista_sdk_data_dir LIST_DIRECTORIES true
  "${CMAKE_CURRENT_LIST_DIR}/../@VTK_SDK_INSTALL_DIR@/vtk-*.data")
list(GET _cvista_sdk_data_dir 0 _cvista_sdk_data_dir)
include("${_cvista_sdk_data_dir}/headers/cmake/vtk-config-version.cmake")
unset(_cvista_sdk_data_dir)
