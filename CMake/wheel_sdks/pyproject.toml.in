[build-system]
requires = ["pybind11", "scikit-build-core"]
build-backend = "scikit_build_core.build"

[project]
name = "cvista-sdk"
version = "@VTK_WHEEL_SDK_VERSION@"
authors = [
  { name = "Alexy Pellegrini", email = "alexy.pellegrini@kitware.com" },
  { name = "Jean-Christophe Fillion-Robin", email = "jcfr@lab78.xyz" },
]
description = "cvista SDK (headers, CMake config, wrap tools) as a first-class Python wheel"
readme = "README.md"
license.file = "LICENSE"
requires-python = ">=3.12"
classifiers = [
  "Development Status :: 4 - Beta",
  "Intended Audience :: Science/Research",
  "Intended Audience :: Developers",
  "License :: OSI Approved :: BSD License",
  "Operating System :: OS Independent",
  "Programming Language :: Python",
  "Programming Language :: Python :: 3",
  "Programming Language :: Python :: 3 :: Only",
  "Programming Language :: Python :: 3.12",
  "Programming Language :: Python :: 3.13",
  "Programming Language :: Python :: 3.14",
  "Topic :: Scientific/Engineering",
  "Typing :: Typed",
]
dependencies = []

[project.urls]
Homepage = "https://github.com/pyvista/cvista"
"Bug Tracker" = "https://github.com/pyvista/cvista/issues"

[project.entry-points."cmake.prefix"]
cvistasdk = "cvista_sdk.cmake"

[project.optional-dependencies]
test = [
  "pytest >=6",
  "pytest-cov >=3",
  "virtualenv",
]

[tool.scikit-build]
minimum-version = "0.8.2"
build-dir = "build/{wheel_tag}"
wheel.packages = ["src/cvista_sdk"]
# The SDK ships headers + CMake config + VTK shared/import libs — platform-
# specific, but NOT tied to any CPython ABI (there is no extension module). Tag
# it py3-none so one wheel serves every 3.12+ interpreter; without this scikit-
# build-core stamps the build interpreter's cp312-cp312 tag and the wheel only
# installs on 3.12. The platform half (linux_x86_64 -> manylinux_2_28_x86_64) is
# relabelled in ci/build-sdk.sh.
wheel.py-api = "py3"

[tool.scikit-build.cmake.define]
VTK_INSTALL_DIR = "@VTK_WHEEL_SDK_VTK_INSTALL_DIR@"
# Carry the abi3 wrapping settings into the wheel_sdks CMake configure so the
# proxy vtk-config can re-export them; a downstream find_package(VTK) then wraps
# its modules with the same stable-ABI configuration this SDK was built with.
CVISTA_ABI3 = "@VTK_WHEEL_SDK_ABI3@"
CVISTA_ABI3_VERSION = "@VTK_WHEEL_SDK_ABI3_VERSION@"
