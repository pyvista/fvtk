# Do not add ExternalData module staging files
.ExternalData_*
.ExternalData/config

# Do not commit baseline image files.
**/Testing/Data/Baseline/*.png

# Exclude compiled Python objects.
*.pyc
*.pyo
__pycache__/

# Exclude macOS .DS_Store files.
.DS_Store

# --- cvista local build artifacts (not part of the source) ---
/build-cvista/
/build-cvista-trim/
/build-cvista-*/
/.pyshim313/
/.ExternalData/
*.whl
__pycache__/
*.py[cod]

# Local agent worktrees (git worktrees registered under .claude); never commit.
.claude/worktrees/
